# App
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://ecoplay:ecoplay@localhost:5432/ecoplay

# JWT
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# Stellar
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_PLATFORM_SECRET_KEY=your_platform_secret_key
STELLAR_PLATFORM_PUBLIC_KEY=your_platform_public_key

# Reward splits (must sum to 100)
REWARD_COLLECTOR_PCT=60
REWARD_AGENT_PCT=30
REWARD_PLATFORM_PCT=10

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_STELLAR_NETWORK=testnet
